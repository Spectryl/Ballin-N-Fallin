; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Ballin N Fallin"
config/description="Ballin N Fallin"
config/version="1.0"
run/main_scene="res://Scenes/Main Scenes/Main Scene.tscn"
config/features=PackedStringArray("4.3", "C#", "GL Compatibility")
run/delta_smoothing=false
boot_splash/show_image=false
boot_splash/fullsize=false
boot_splash/use_filter=false
config/icon="res://Assets/Sprites/Player/Player.png"
config/windows_native_icon="res://Assets/Sprites/Ballin N Fallin.ico"

[audio]

buses/default_bus_layout="res://Materials/default_bus_layout.tres"

[autoload]

AntialiasedLine2DTexture="*res://addons/antialiased_line2d/texture.gd"

[display]

window/size/viewport_width=3840
window/size/viewport_height=2160
window/size/mode=4
window/size/resizable=false
window/stretch/mode="canvas_items"

[dotnet]

project/assembly_name="Ballin N Fallin"

[editor]

naming/scene_name_casing=1

[editor_plugins]

enabled=PackedStringArray("res://addons/antialiased_line2d/plugin.cfg")

[file_customization]

folder_colors={
"res://Assets/": "red",
"res://Levels/": "yellow",
"res://Levels/Bomb Ball Levels/": "gray",
"res://Levels/Crown the King Levels/": "pink",
"res://Levels/Deathmatch Levels/": "blue",
"res://Levels/Domination Levels/": "red",
"res://Levels/Golf Levels/": "teal",
"res://Levels/Hot Potato Levels/": "gray",
"res://Levels/King of the Hill Levels/": "green",
"res://Levels/Race Levels/": "orange",
"res://Levels/Soccer Levels/": "green",
"res://Levels/Survival Levels/": "red",
"res://Levels/Target Test Levels/": "red",
"res://Levels/Volleyball Levels/": "yellow",
"res://Materials/": "teal",
"res://Scenes/": "purple",
"res://Scenes/Object Scenes/Mode Stuff/Ballin to the Bank/": "yellow",
"res://Scenes/Object Scenes/Mode Stuff/Bomb Ball/": "gray",
"res://Scenes/Object Scenes/Mode Stuff/Domination/": "red",
"res://Scenes/Object Scenes/Mode Stuff/Golf/": "teal",
"res://Scenes/Object Scenes/Mode Stuff/King of the Hill/": "green",
"res://Scenes/Object Scenes/Mode Stuff/Payload/": "yellow",
"res://Scenes/Object Scenes/Mode Stuff/Race/": "orange",
"res://Scenes/Object Scenes/Mode Stuff/Survival/": "red",
"res://Scenes/Object Scenes/Mode Stuff/Volleyball/": "yellow",
"res://Scripts/": "green",
"res://Scripts/Modes/Ballin to the Bank/": "yellow",
"res://Scripts/Modes/Bomb Ball/": "gray",
"res://Scripts/Modes/Crown the King/": "pink",
"res://Scripts/Modes/Deathmatch/": "blue",
"res://Scripts/Modes/Domination/": "red",
"res://Scripts/Modes/Golf/": "teal",
"res://Scripts/Modes/Hot Potato/": "gray",
"res://Scripts/Modes/Payload/": "yellow",
"res://Scripts/Modes/Race/": "orange",
"res://Scripts/Modes/Survival/": "red"
}

[filesystem]

import/blender/enabled=false

[global_group]

Regain=""
Bump=""
Trash=""
NoRegain=""

